# ============ 数据库（后端） ============
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=road_conditions

# ============ 后端服务 ============
PORT=4000
# 生产环境务必替换为强随机字符串
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES=8h

# ============ AI 服务（后端代理使用，不再暴露到前端） ============
# DeepSeek 文本模型
DEEPSEEK_API_KEY=
# 通义千问视觉模型
QWEN_API_KEY=
QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# ============ 前端可见变量（必须以 VITE_ 前缀） ============
# 百度地图 JS API / 街景 AK
VITE_BAIDU_AK=
# 坐标系模式：wgs84（默认）或 gcj02
VITE_COORDINATE_MODE=wgs84
